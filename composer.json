{
    "name": "schaefersoft/laravel-llms-txt",
    "version": "1.0.2",
    "description": "Automatically generate llms.txt and llms-full.txt for Laravel applications",
    "keywords": [
        "laravel",
        "llms",
        "llms.txt",
        "ai",
        "schaefersoft"
    ],
    "homepage": "https://github.com/schaefersoft/laravel-llms-txt",
    "license": "MIT",
    "authors": [
        {
            "name": "SchaeferSoft",
            "email": "info@schaefersoft.ch",
            "homepage": "https://schaefersoft.ch",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "SchaeferSoft\\LaravelLlmsTxt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SchaeferSoft\\LaravelLlmsTxt\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "./vendor/bin/pest",
        "test-coverage": "./vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SchaeferSoft\\LaravelLlmsTxt\\LlmsTxtServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
